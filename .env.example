# =============================================================
# SlotMachine 환경 변수 템플릿
# 실제 값은 .env.local 에 작성하고 절대 커밋하지 않는다.
# =============================================================

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here

# --- 임베딩 프로바이더 ---
# 선택: jina | voyage | openai | gemini | ollama
EMBEDDING_PROVIDER=jina

# 프로바이더별 기본 모델
#   jina    → jina-embeddings-v3
#   voyage  → voyage-3 | voyage-3-lite
#   openai  → text-embedding-3-small | text-embedding-3-large
#   gemini  → text-embedding-004
#   ollama  → nomic-embed-text | mxbai-embed-large
EMBEDDING_MODEL=jina-embeddings-v3

# ※ 주의: 프로바이더 변경 시 벡터 차원이 달라지므로 Full Re-sync 필요

# 프로바이더별 API Key (사용하는 프로바이더의 항목만 설정)
# JINA_API_KEY=your_jina_api_key_here
# VOYAGE_API_KEY=your_voyage_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# Ollama 사용 시 엔드포인트 (기본값: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# --- Obsidian Vault ---
VAULT_PATH=/path/to/your/obsidian/vault
INBOX_FOLDER=INBOX

# --- Git ---
GIT_REPO_URL=https://github.com/your/vault-repo
# SSH 키 경로 (SSH 인증 사용 시)
# GIT_SSH_KEY_PATH=~/.ssh/id_ed25519

# --- Webhook 서버 ---
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_SECRET=your_webhook_secret_here

# --- 환경 ---
# local | staging | production
ENV=local

# --- 로깅 ---
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
